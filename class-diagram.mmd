    %% ============ RELATIONSHIPS ============

    %% Controller → Service
    UserController --> UserService : @Autowired
    SourceFolderController --> SourceFolderService : @Autowired
    ParseSourceCodeController --> ParseSourceCodeService : @Autowired
    StaticAnalysisController --> StaticAnalysisService : @Autowired
    AnalysisReportController --> AnalysisReportService : @Autowired
    DynamicController --> DynamicAnalysisService : @Autowired

    %% Service Interface → Implementation
    UserService <|.. UserServiceImpl : implements
    SourceFolderService <|.. SourceFolderServiceImpl : implements
    ParseSourceCodeService <|.. ParseSourceCodeServiceImpl : implements
    StaticAnalysisService <|.. StaticAnalysisServiceImpl : implements
    DynamicAnalysisService <|.. DynamicAnalysisServiceImpl : implements
    AnalysisReportService <|.. AnalysisReportServiceImpl : implements
    JsonFileService <|.. JsonFileServiceImpl : implements
    AnalysisJobService <|.. AnalysisJobServiceImpl : implements

    %% Service Impl → Mapper
    UserServiceImpl --> UserMapper
    UserServiceImpl --> IngestMapper
    UserServiceImpl --> ParseSourceCodeMapper
    UserServiceImpl --> AnalysisReportMapper
    UserServiceImpl --> StaticAnalysisMapper
    SourceFolderServiceImpl --> IngestMapper
    SourceFolderServiceImpl --> FileMapper
    SourceFolderServiceImpl --> ParseSourceCodeMapper
    ParseSourceCodeServiceImpl --> ParseSourceCodeMapper
    ParseSourceCodeServiceImpl --> FileMapper
    ParseSourceCodeServiceImpl --> IngestMapper
    StaticAnalysisServiceImpl --> StaticAnalysisMapper
    StaticAnalysisServiceImpl --> ParseSourceCodeMapper
    AnalysisReportServiceImpl --> AnalysisReportMapper

    %% Service Impl → Service
    ParseSourceCodeServiceImpl --> JsonFileService
    StaticAnalysisServiceImpl --> AnalysisReportService

    %% Service Impl → ParsingUtil
    ParseSourceCodeServiceImpl --> ParsingUtil : uses

    %% ParsingUtil → Common Analyzers
    ParsingUtil --> JspContentAnalyzer : uses
    ParsingUtil --> JasperJspAnalyzer : uses
    ParsingUtil --> JsfAnalyzer : uses
    ParsingUtil --> JsfMigrationIssueDetector : uses
    ParsingUtil --> JsonFileService : uses

    %% ParsingUtil → Common Models
    ParsingUtil --> JavaClassInfo : creates
    ParsingUtil --> JspFileInfo : creates
    ParsingUtil --> JsfFileInfo : creates
    ParsingUtil --> XmlFileInfo : creates
    ParsingUtil --> IssueInfo : creates
    ParsingUtil --> AnalysisResultReport : aggregates

